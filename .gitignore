# ── Python ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
*.spec

# ── Virtual environments ─────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Test / coverage artefacts ────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.xml

# ── IDE / editor ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
.continue/*
.claude/*

# ── OS ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Project runtime data (keep structure, ignore actual files) ───────────
# Processed outputs and source images are not version-controlled
input/*
!input/.gitkeep
output/*
!output/.gitkeep
fonts/*
!fonts/.gitkeep
models/*
!models/.gitkeep

# ── PaddleOCR auto-downloaded model cache ────────────────────────────────
~/.paddleocr/
koharu_windows_x64.exe
src/police/*